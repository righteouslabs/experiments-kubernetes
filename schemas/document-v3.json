{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Document V3",
  "description": "NON-ADDITIVE change from V2: 'tags' is now an array of weighted objects instead of plain strings. This would break a V2 consumer. Dapr routing ensures V2 consumers never see V3 documents.",
  "type": "object",
  "required": ["id", "schemaVersion", "title", "body", "author", "tags", "priority", "metadata", "createdAt"],
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "schemaVersion": {
      "type": "integer",
      "const": 3
    },
    "title": {
      "type": "string"
    },
    "body": {
      "type": "string"
    },
    "author": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "description": "NON-ADDITIVE: changed from string[] (V2) to weighted objects",
      "items": {
        "type": "object",
        "required": ["name", "weight"],
        "properties": {
          "name": {
            "type": "string"
          },
          "weight": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    },
    "priority": {
      "type": "string",
      "enum": ["HIGH", "MEDIUM", "LOW"]
    },
    "metadata": {
      "type": "object",
      "required": ["source", "region", "correlationId"],
      "properties": {
        "source": {
          "type": "string",
          "enum": ["web", "mobile", "api", "batch"]
        },
        "region": {
          "type": "string"
        },
        "correlationId": {
          "type": "string",
          "format": "uuid"
        }
      }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
