{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Document V1",
  "description": "Base document schema - core fields only",
  "type": "object",
  "required": ["id", "schemaVersion", "title", "body", "createdAt"],
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "title": {
      "type": "string"
    },
    "body": {
      "type": "string"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
